<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header con avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_header_gradient"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp">

            <!-- Avatar círculo -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text=" "
                    android:textSize="42sp"
                    android:gravity="center"
                    android:background="@drawable/bg_avatar_circle"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvAvatarName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Héroe"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvAvatarLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nivel 1 · Aprendiz 🌱"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/primary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card puntos + XP -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mis puntos"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvAvatarPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="22sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/primary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Siguiente nivel"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_hint"/>

                        <TextView
                            android:id="@+id/tvNextLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Faltan 500 pts"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/cat_alma"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbXp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/cat_alma"
                        android:progressBackgroundTint="@color/cat_alma_bg"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card stats vitales -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stats vitales"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- HP -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="❤️" android:textSize="16sp"/>
                        <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                            android:text="HP" android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/cat_cuerpo" android:layout_marginStart="8dp"/>
                        <ProgressBar android:id="@+id/pbHp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                            android:progressTint="@color/cat_cuerpo"
                            android:progressBackgroundTint="@color/cat_cuerpo_bg"/>
                        <TextView android:id="@+id/tvHpValue" android:layout_width="52dp"
                            android:layout_height="wrap_content" android:text="100/100"
                            android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_hint" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Alma -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="😊" android:textSize="16sp"/>
                        <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                            android:text="Alma" android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/cat_alma" android:layout_marginStart="8dp"/>
                        <ProgressBar android:id="@+id/pbHappiness"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                            android:progressTint="@color/cat_alma"
                            android:progressBackgroundTint="@color/cat_alma_bg"/>
                        <TextView android:id="@+id/tvHappinessValue" android:layout_width="52dp"
                            android:layout_height="wrap_content" android:text="100/100"
                            android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_hint" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Espíritu -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="🔮" android:textSize="16sp"/>
                        <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                            android:text="Espíritu" android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/cat_espiritu" android:layout_marginStart="8dp"/>
                        <ProgressBar android:id="@+id/pbMana"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                            android:progressTint="@color/cat_espiritu"
                            android:progressBackgroundTint="@color/cat_espiritu_bg"/>
                        <TextView android:id="@+id/tvManaValue" android:layout_width="52dp"
                            android:layout_height="wrap_content" android:text="100/100"
                            android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_hint" android:gravity="end"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cerrar sesión -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Cerrar sesión"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/danger"
                app:strokeColor="@color/danger"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@color/danger_surface"
                app:cornerRadius="26dp"
                android:layout_marginBottom="100dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>