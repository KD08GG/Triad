<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Emoji avatar grande -->
            <TextView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:text=""
                android:textSize="56sp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvAvatarName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Héroe"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvAvatarLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nivel 1 · Aprendiz"
                android:textSize="14sp"
                android:textColor="@color/primary_light"/>

        </LinearLayout>

        <!-- Card puntos + XP -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Puntos"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvAvatarPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_light"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Barra XP -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progreso al siguiente nivel"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <ProgressBar
                    android:id="@+id/pbXp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/cat_alma"
                    android:progressBackgroundTint="@color/divider"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvNextLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Faltan 500 pts para Nivel 2"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card stats vitales -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats vitales"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>

                <!-- HP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="❤️"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="HP"
                        android:textSize="13sp"
                        android:textColor="@color/cat_cuerpo"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp"/>
                    <ProgressBar
                        android:id="@+id/pbHp" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:progressTint="@color/cat_cuerpo"
                        android:progressBackgroundTint="@color/divider"/>
                    <TextView android:id="@+id/tvHpValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="100/100"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Happiness -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="😊"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Alma" android:textSize="13sp"
                        android:textColor="@color/cat_alma"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp"/>
                    <ProgressBar
                        android:id="@+id/pbHappiness" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:progressTint="@color/cat_alma"
                        android:progressBackgroundTint="@color/divider"/>
                    <TextView android:id="@+id/tvHappinessValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="100/100"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Mana -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="🔮"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Espíritu"
                        android:textSize="13sp"
                        android:textColor="@color/cat_espiritu"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp"/>
                    <ProgressBar
                        android:id="@+id/pbMana" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:progressTint="@color/cat_espiritu"
                        android:progressBackgroundTint="@color/divider"/>
                    <TextView android:id="@+id/tvManaValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="100/100"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón cerrar sesión en rojo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cerrar sesión"
            android:textSize="15sp"
            android:textColor="#FF4444"
            app:strokeColor="#FF4444"
            app:strokeWidth="1.5dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>
</ScrollView>