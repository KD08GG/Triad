<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_header_gradient"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:text="H"
                    android:textSize="36sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/primary"
                    android:gravity="center"
                    android:background="@drawable/bg_avatar_circle"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvAvatarName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heroe"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_level_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/tvAvatarLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NV. 1 - APRENDIZ"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/primary"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- XP Progress card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Stacked Coins"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tvAvatarPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pts"
                        android:textSize="24sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/cat_alma"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Siguiente nivel"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_hint"/>

                    <TextView
                        android:id="@+id/tvNextLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Faltan 500 pts"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/primary"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbXp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/primary_surface"/>
            </LinearLayout>

            <!-- Stats Pilares card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progreso de Pilares"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp"/>

                <!-- Cuerpo -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="@color/cat_cuerpo"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="64dp" android:layout_height="wrap_content"
                        android:text="Cuerpo" android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_cuerpo"/>
                    <ProgressBar android:id="@+id/pbCuerpo"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                        android:progressTint="@color/cat_cuerpo"
                        android:progressBackgroundTint="@color/cat_cuerpo_bg"/>
                    <TextView android:id="@+id/tvCuerpoValue" android:layout_width="52dp"
                        android:layout_height="wrap_content" android:text="0 tasks"
                        android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_hint" android:gravity="end"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Alma -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="@color/cat_alma"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="64dp" android:layout_height="wrap_content"
                        android:text="Alma" android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_alma"/>
                    <ProgressBar android:id="@+id/pbAlma"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                        android:progressTint="@color/cat_alma"
                        android:progressBackgroundTint="@color/cat_alma_bg"/>
                    <TextView android:id="@+id/tvAlmaValue" android:layout_width="52dp"
                        android:layout_height="wrap_content" android:text="0 tasks"
                        android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_hint" android:gravity="end"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Espiritu -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="@color/cat_espiritu"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="64dp" android:layout_height="wrap_content"
                        android:text="Espíritu" android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_espiritu"/>
                    <ProgressBar android:id="@+id/pbEspiritu"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                        android:progressTint="@color/cat_espiritu"
                        android:progressBackgroundTint="@color/cat_espiritu_bg"/>
                    <TextView android:id="@+id/tvEspirituValue" android:layout_width="52dp"
                        android:layout_height="wrap_content" android:text="0 tasks"
                        android:textSize="11sp" android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_hint" android:gravity="end"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Cerrar sesion -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Cerrar sesion"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/danger"
                app:strokeColor="@color/danger"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/danger_surface"
                app:cornerRadius="16dp"
                android:layout_marginBottom="100dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
