<?xml version="1.0" encoding="utf-8"?>
<!--
  AppBarLayout + behavior="@string/appbar_scrolling_view_behavior"
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- AppBarLayout: ancla el header correctamente -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:elevation="0dp"
        app:liftOnScroll="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="16dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦ Bienvenido a Triad"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Elige las misiones que quieres completar para equilibrar tu vida y romper con la procrastinación."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvSelectionCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona al menos una misión"
                android:textSize="13sp"
                android:textColor="@color/primary_light"
                android:textStyle="italic"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- RecyclerView: responde al AppBar gracias al behavior -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTareasPredefinidas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="200dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- Panel inferior fijo — siempre visible, nunca se mueve -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="8dp"
        android:layout_gravity="bottom">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Agregar otra misión..."
            app:boxBackgroundColor="@color/background"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCustom"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="+ Agregar"
                android:textSize="14sp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:textColor="@color/primary"
                app:backgroundTint="@android:color/transparent"
                android:layout_marginEnd="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinuar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="¡Comenzar mi aventura!"
                android:textSize="14sp"
                android:enabled="false"
                android:alpha="0.5"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>