<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header fijo arriba -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="16dp"
        android:background="@color/background"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido a Triad"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elige las misiones que quieres completar para equilibrar tu vida y romper con la procrastinación."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="12dp"/>

        <!-- Contador de seleccionadas -->
        <TextView
            android:id="@+id/tvSelectionCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona al menos una misión"
            android:textSize="13sp"
            android:textColor="@color/primary_light"
            android:textStyle="italic"/>

    </LinearLayout>

    <!-- Lista de tareas (scrolleable) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTareasPredefinidas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="160dp"
        android:paddingBottom="260dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- Panel inferior fijo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_anchor="@id/rvTareasPredefinidas"
        app:layout_anchorGravity="bottom"
        android:layout_gravity="bottom">

        <!-- Campo para agregar tarea personalizada -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Agregar otra misión..."
            app:boxBackgroundColor="@color/background"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/text_secondary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"/>

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCustom"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="+ Agregar"
                android:textSize="14sp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:textColor="@color/primary"
                app:backgroundTint="@android:color/transparent"
                android:layout_marginEnd="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinuar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="¡Comenzar mi aventura!"
                android:textSize="14sp"
                android:enabled="false"
                android:alpha="0.5"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>