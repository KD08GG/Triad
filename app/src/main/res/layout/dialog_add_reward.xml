<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Recompensa"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp"/>

        <!-- Nombre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMBRE"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="¿Que recompensa quieres ganar?"
            app:boxBackgroundColor="@color/surface_elevated"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRewardName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_regular"
                android:textSize="15sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Costo en puntos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COSTO EN PUNTOS"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Points row card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Puntos necesarios"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/surface_elevated"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxStrokeColor="@color/primary"
                app:suffixText="pts"
                app:suffixTextColor="@color/text_hint"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRewardPoints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="100"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Tip card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@color/primary"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sugerencia: si ganas ~150 pts/dia, una recompensa de 150 pts se logra en 1 dia completo."
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
