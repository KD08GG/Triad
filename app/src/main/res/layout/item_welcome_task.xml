<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:id="@+id/cardTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/bg_task_unselected"
        android:clickable="true"
        android:focusable="true">

        <!-- Icon container -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp">

            <TextView
                android:id="@+id/tvTaskIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="20sp"
                android:background="@drawable/circle_indicator"
                android:backgroundTint="#1E293B"
                android:textColor="@color/primary"/>
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Misión de bienvenida"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvTaskPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+50 pts"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/primary"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Check estilo moderno -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteTask"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/text_hint"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="20dp"/>
    </LinearLayout>

</FrameLayout>