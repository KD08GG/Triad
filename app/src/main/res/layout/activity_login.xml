<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp">

        <!-- Blob decorativo superior -->
        <View
            android:id="@+id/blobTop"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/blob_gradient_top"
            android:alpha="0.6"
            android:translationX="80dp"
            android:translationY="-80dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Logo / título -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="80dp"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="36sp"
                android:textColor="@color/primary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triad"
                android:textSize="40sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equilibra tu vida"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Card de formulario -->
        <androidx.cardview.widget.CardView
            android:id="@+id/formCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Correo electrónico"
                    app:boxBackgroundColor="@color/background"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/text_secondary"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/primary_light"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="15sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña"
                    app:boxBackgroundColor="@color/background"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/text_secondary"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/primary_light"
                    app:endIconMode="password_toggle"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="15sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón Login -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Iniciar sesión"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="27dp"
                    android:layout_marginBottom="10dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <!-- Botón Registro -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Crear cuenta"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1.5dp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="27dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Separador "o continúa con" -->
        <LinearLayout
            android:id="@+id/dividerSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/formCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  o continúa con  "
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_hint"/>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider"/>
        </LinearLayout>

        <!-- Botones sociales -->
        <LinearLayout
            android:id="@+id/socialSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/dividerSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Google -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con Google"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:icon="@drawable/ic_google"
                app:iconTint="@null"
                app:strokeColor="@color/divider"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="26dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <!-- Facebook -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebook"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con Facebook"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="26dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <!-- GitHub -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGithub"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con GitHub"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1.5dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="26dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <!-- Anónimo -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnonymous"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Continuar sin cuenta"
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                app:backgroundTint="@android:color/transparent"
                android:layout_marginBottom="32dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>