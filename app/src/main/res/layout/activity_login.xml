<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp">

        <!-- Subtle teal glow top-right -->
        <View
            android:id="@+id/blobTop"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/blob_gradient_top"
            android:alpha="0.8"
            android:translationX="60dp"
            android:translationY="-60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Logo / titulo -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="72dp"
            android:paddingBottom="36dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Logo mark: three triangles -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textSize="32sp"
                android:textColor="@color/primary"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triad"
                android:textSize="42sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equilibra tu vida. Gana la batalla."
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:id="@+id/formCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_surface_card"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/headerSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar sesión"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="20dp"/>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo electrónico"
                app:boxBackgroundColor="@color/surface_elevated"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/divider"
                
                app:hintTextColor="@color/text_hint"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/text_hint"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                app:boxBackgroundColor="@color/surface_elevated"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/divider"
                app:hintTextColor="@color/text_hint"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_hint"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_hint"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Boton Login -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Entrar al campo de batalla"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="14sp"
                android:textColor="#0F172A"
                app:backgroundTint="@color/primary"
                app:cornerRadius="16dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <!-- Boton Registro -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Crear cuenta nueva"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="14sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/surface_elevated"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>

        <!-- Separador -->
        <LinearLayout
            android:id="@+id/dividerSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/formCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  o continúa con  "
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_hint"/>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/divider"/>
        </LinearLayout>

        <!-- Botones sociales -->
        <LinearLayout
            android:id="@+id/socialSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/dividerSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con Google"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:icon="@drawable/ic_google"
                app:iconTint="@null"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="16dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebook"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con Facebook"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="16dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGithub"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="  Continuar con GitHub"
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/surface"
                app:cornerRadius="16dp"
                android:layout_marginBottom="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnonymous"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Continuar sin cuenta"
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                app:backgroundTint="@android:color/transparent"
                android:layout_marginBottom="40dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
