<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_surface_card"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Icon bg -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="14dp">
        <ImageView
            android:id="@+id/ivRewardIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_indicator"
            android:backgroundTint="@color/cat_alma_bg"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/cat_alma"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRewardName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recompensa"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tvRewardDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Canjeado hoy"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Activate button (visible only in "pendientes" tab) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnActivate"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="ACTIVAR"
        android:textSize="11sp"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="#0F172A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="8dp"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>
