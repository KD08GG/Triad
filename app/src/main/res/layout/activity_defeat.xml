<?xml version="1.0" encoding="utf-8"?>
<!-- activity_defeat.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="700dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💀"
            android:textSize="72sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Has caído"
            android:textSize="30sp"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No completaste tus misiones y pagaste el precio"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/danger_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Puntos perdidos"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvPuntosPercidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-0 pts"
                    android:textSize="42sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/danger"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvDefeatMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Todos caemos. Los héroes se levantan."
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/primary"
            android:gravity="center"
            android:textStyle="italic"
            android:layout_marginBottom="40dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuarDerrota"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Levantarse y continuar"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="27dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</ScrollView>