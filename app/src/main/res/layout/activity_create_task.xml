<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none"
    android:fillViewport="true"
    tools:context=".CreateTaskActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="52dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tvCreateHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nueva Mision"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_semibold"/>
        </LinearLayout>

        <!-- Titulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TITULO"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="¿Que mision quieres aceptar?"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_regular"
                android:textSize="15sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Categoria -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PILAR"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <!-- Pillar selector: large icon cards -->
        <LinearLayout
            android:id="@+id/toggleGroupCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <!-- Cuerpo -->
            <LinearLayout
                android:id="@+id/btnCatCuerpo"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_cuerpo"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="C"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/cat_cuerpo"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cuerpo"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/cat_cuerpo"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Alma -->
            <LinearLayout
                android:id="@+id/btnCatAlma"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_alma"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/cat_alma"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alma"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/cat_alma"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Espiritu -->
            <LinearLayout
                android:id="@+id/btnCatEspiritu"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_espiritu"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/cat_espiritu"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Espiritu"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/cat_espiritu"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Deberes -->
            <LinearLayout
                android:id="@+id/btnCatDeberes"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_teal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deberes"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Puntos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PUNTOS DE RECOMPENSA"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <!-- Points input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Valor de la mision"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/surface_elevated"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxStrokeColor="@color/primary"
                app:suffixText="pts"
                app:suffixTextColor="@color/text_hint"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPointsValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="50"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="16sp"
                    android:gravity="center"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Recurrente switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mision Recurrente"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Se reinicia cada dia"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchRecurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/primary"
                app:trackTint="@color/primary_surface"/>
        </LinearLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Aceptar Mision"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:textColor="#0F172A"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</ScrollView>
