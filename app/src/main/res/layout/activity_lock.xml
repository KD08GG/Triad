<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Mapa ocupa mitad superior -->
    <fragment
        android:id="@+id/mapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lockPanel"
        app:layout_constraintHeight_percent="0.48"/>

    <!-- Panel inferior -->
    <ScrollView
        android:id="@+id/lockPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/mapView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App bloqueada"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/danger"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quedaste sin puntos. Para desbloquear Triad necesitas correr 2 kilómetros continuos."
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp"/>

            <!-- Distancia -->
            <TextView
                android:id="@+id/tvDistanciaRecorrida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 m recorridos"
                android:textSize="30sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvDistanciaRestante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2000 m restantes"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="14dp"/>

            <!-- Barra progreso -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ProgressBar
                    android:id="@+id/pbCarrera"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/cat_cuerpo"
                    android:progressBackgroundTint="@color/cat_cuerpo_bg"/>

                <TextView
                    android:id="@+id/tvPorcentajeCarrera"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/cat_cuerpo"
                    android:gravity="end"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Si cierras la app, debes empezar de nuevo"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_hint"
                android:textStyle="italic"
                android:layout_marginBottom="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIniciarCarrera"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Iniciar rastreo GPS"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                app:backgroundTint="@color/cat_cuerpo"
                app:cornerRadius="27dp"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>