<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header con gradiente suave -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ Buenos días"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvHomeUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Héroe"
                android:textSize="28sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvHomeLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nivel 1 · Aprendiz"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/primary"/>

        </LinearLayout>

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card puntos grande -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/primary"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="22dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Puntos totales"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="#CCCBFF"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvHomePoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="34sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cards misiones — fila -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Pendientes -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/accent_pink_light"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvPendingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="30sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/cat_cuerpo"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendientes"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Completadas -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/cat_deberes_bg"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCompletedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="30sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/cat_deberes"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completadas"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Card progreso del día -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Progreso de hoy"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tvProgressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/primary"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbDailyProgress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/primary_surface"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón debug (solo pruebas) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDebugReinicio"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="solo prueba (Simula día siguiente)"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/danger"
                app:strokeColor="@color/danger"
                app:strokeWidth="1dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                android:layout_marginBottom="80dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>