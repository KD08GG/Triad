<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HUD HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="20dp">

            <!-- User row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="14dp">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="H"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/primary"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_circle"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Buenos días"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_hint"/>

                    <TextView
                        android:id="@+id/tvHomeUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Héroe"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Level badge (Contenedor sin ID conflictivo) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_level_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvHomeLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NV.1 APRENDIZ"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/primary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== VITAL STATS (HP prominente) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="16dp">

                <!-- XP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="16dp"
                        android:layout_height="wrap_content"
                        android:text="◆"
                        android:textSize="10sp"
                        android:textColor="@color/primary"/>

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="XP"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/primary"
                        android:layout_marginStart="6dp"/>

                    <ProgressBar
                        android:id="@+id/pbDailyProgress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/primary_surface"/>

                    <TextView
                        android:id="@+id/tvProgressLabel"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/primary"
                        android:gravity="end"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Currency / Coins -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="16dp"
                        android:layout_height="wrap_content"
                        android:text="◆"
                        android:textSize="10sp"
                        android:textColor="@color/cat_alma"/>

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="SC"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_alma"
                        android:layout_marginStart="6dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvHomePoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pts"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_alma"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ===== CONTENT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Stats cards row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Pendientes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_surface_card"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvPendingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/cat_cuerpo"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pendientes"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <!-- Completadas -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_surface_card"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCompletedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completadas"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tip card: explain the game -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_surface_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como funciona Triad"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"/>

                <!-- Pillar indicators -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_pill_cuerpo"
                        android:paddingVertical="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CUERPO" android:textSize="10sp"
                            android:fontFamily="@font/poppins_semibold" android:textColor="@color/cat_cuerpo"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_pill_alma"
                        android:paddingVertical="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ALMA" android:textSize="10sp"
                            android:fontFamily="@font/poppins_semibold" android:textColor="@color/cat_alma"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_pill_espiritu"
                        android:paddingVertical="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ESPIRITU" android:textSize="10sp"
                            android:fontFamily="@font/poppins_semibold" android:textColor="@color/cat_espiritu"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Completa misiones para ganar XP. Si tu HP llega a 0, la app se bloquea. Corre 2 km para liberarla."
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- Debug button — visible pero minimal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDebugReinicio"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Simular siguiente dia (debug)"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_hint"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="8dp"
                android:layout_marginBottom="80dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
