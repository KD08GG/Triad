<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="0dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Misiones"
                        android:textSize="26sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completa tus tareas del dia"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- HP indicator chip -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_card"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="@color/hp_color"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvHpChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HP 80"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/hp_color"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Pillar filter chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- All -->
                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Todos"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/background"
                        android:background="@drawable/bg_pill_teal"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/chipCuerpo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Cuerpo"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_cuerpo"
                        android:background="@drawable/bg_pill_cuerpo"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/chipAlma"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Alma"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_alma"
                        android:background="@drawable/bg_pill_alma"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/chipEspiritu"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Espiritu"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/cat_espiritu"
                        android:background="@drawable/bg_pill_espiritu"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTasks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:tint="#0F172A"
        app:elevation="4dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
