<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Triad" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#2DD4BF</item>
        <item name="colorPrimaryVariant">#0D9488</item>
        <item name="colorOnPrimary">#0F172A</item>
        <item name="colorSecondary">#FDA4AF</item>
        <item name="colorOnSecondary">#0F172A</item>
        <item name="colorSurface">#1E293B</item>
        <item name="colorOnSurface">#F1F5F9</item>
        <item name="android:colorBackground">#0F172A</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="materialAlertDialogTheme">@style/Triad.AlertDialog</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Triad.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">#2DD4BF</item>
        <item name="android:textColor">#0F172A</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Triad.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">#334155</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">#F1F5F9</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="backgroundTint">#1E293B</item>
    </style>

    <style name="Triad.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#1E293B</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#334155</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Triad.AlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">#1E293B</item>
        <item name="colorPrimary">#2DD4BF</item>
        <item name="android:textColorPrimary">#F1F5F9</item>
        <item name="android:textColorSecondary">#94A3B8</item>
    </style>
</resources>
